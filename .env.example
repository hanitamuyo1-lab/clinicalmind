# Firebase project config (Project settings → General → Your apps → SDK setup and configuration)
# Copy this file to .env.local and fill in your project's values.
# If these are left unset, the app falls back to a local-only (localStorage) progress store
# so it still runs standalone without a Firebase project.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
