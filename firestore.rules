rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each anonymous user can only read/write their own progress document,
    // identified by their Firebase Auth uid. No document lists personal data —
    // just study progress (explored nodes, flashcard ratings, quiz scores, streak).
    match /progress/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
